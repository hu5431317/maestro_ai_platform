# ══════════════════════════════════════════════════════
# Maestro AI Platform - LLM API Keys Configuration
# ══════════════════════════════════════════════════════
#
# 使用说明:
#   1. 复制此文件为 .env:  cp config/.env.example config/.env
#   2. 填写实际的 API Key
#   3. 至少配置一个 AI 提供商的 API Key
#
# AI 提供商选择:
#   - DeepSeek (推荐):  性价比最高，中文支持好，适合大多数场景
#   - OpenAI:           兼容性最好，适合对质量要求较高的场景
#   - Anthropic Claude: 适合需要深度分析的场景

# ── DeepSeek (性价比高，推荐默认使用) ──
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ── OpenAI ──
OPENAI_API_KEY=your_openai_api_key_here

# ── Anthropic Claude ──
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── 默认 AI 配置 ──
# AI_PROVIDER 可选值: deepseek | openai | anthropic
AI_PROVIDER=deepseek

# AI_MODEL 可选值 (按提供商):
#   deepseek:  deepseek-chat, deepseek-reasoner
#   openai:    gpt-4o, gpt-4-turbo, gpt-3.5-turbo
#   anthropic: claude-3-5-sonnet-20241022, claude-3-opus-20240229
AI_MODEL= deepseek-v4-pro

# ── Maestro CLI 路径 ──
# 如果 maestro 不在系统 PATH 中，请指定完整路径
# Windows 示例: C:\\Users\\YourName\\.maestro\\bin\\maestro.bat
# macOS 示例:   /usr/local/bin/maestro
MAESTRO_CLI_PATH=maestro
